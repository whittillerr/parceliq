{
  "metadata": {
    "source": "Sec. 54-301, Chapter 54, City of Charleston Code of Ordinances",
    "version": "NOV 14, 2025",
    "transcription_date": "2026-03-26",
    "notes": [
      "NR = Not Required (no restriction). Encoded as null with 'nr' in unrestricted_fields.",
      "NA = Not Applicable (use not allowed). Encoded as null with 'na' in not_applicable_fields.",
      "Heights in format 'ft/stories'. Some districts have feet only or stories only.",
      "Lot areas for residential are per-family minimums in SF. Numbers in parentheses are du/acre.",
      "Footnotes are critical — see footnotes object."
    ]
  },
  "footnotes": {
    "1": "Attached single-family dwellings (townhomes, row houses) permitted. See Article 3: Part 11.",
    "2": "'Building' and 'Lot Occupancy' defined in Section 54-120.",
    "3": "Minimum distance between residences not joined by common wall: 3 feet.",
    "5": "See Article 5: Exceptions and Modifications, Part 2 Exceptions to Height and Setback Requirements.",
    "8": "UNIVERSAL HEIGHT CAP: No structure shall exceed a height equal to 3× the least dimension, measured from ROW center to building face. Applies in ALL districts.",
    "9": "CRITICAL: Old City Height Districts (Article 3: Part 2) SHALL APPLY and override this table. Where there is a conflict, the Height District controls.",
    "10": "Front/rear yard minimums don't preclude Table 3.2 (Driveway/Building Setback for Business/Office/Industrial). Table 3.2 priority if conflict.",
    "11": "Staff reviews site plans for DR districts — structure location, parking, open space, environmental features.",
    "12": "DENSITY: DR-6 = 6 du/acre. DR-3 (non-mobile) and DR-9 = 9 du/acre. DR-12 = 12 du/acre.",
    "13": "Min lot area calculated only on HIGH GROUND. For SR-6, STR, DR-1, DR-1F, DR-2, DR-2F, DR-3, DR-6, DR-9, DR-12 lots fronting a street with alley access at rear: lot area may be reduced by alley ROW area.",
    "14": "UC DENSITY: Buildings existing as of 1/1/1993 in non-residential zones may include dwellings: 1BR=550 SF, 2BR=750 SF, 3BR=1,000 SF, 4BR=1,250 SF. Density at 43.6 du/ac but only in pre-1993 structures.",
    "17": "Johns Island Overlay: 30 ft building setback from OCRM critical line adjacent to waterways/saltwater wetlands.",
    "18": "SR-8 FRONT SETBACK: Average front setback of buildings on lots on either side, ±5 ft.",
    "19": "SR-8 REAR SETBACK: Marshfront lots: 60 ft from OCRM critical line. All other lots: 25 ft.",
    "20": "SR-8 ACCESSORY: Min 100 ft from front street (or front setback of principal, whichever less). Side street min 35 ft.",
    "21": "Affordable Housing: min lot area, setbacks, frontage and max lot occupancy set by Sec. 54-207.",
    "22": "Neighborhood Districts: setbacks from ROW based on street type. No min side/rear. No max lot occupancy. See Section 54-294.",
    "23": "C and RR-1: permits up to 4 one-family detached dwellings as conditional use per Section 54-207, t.",
    "24": "For density and height information, see Section 54-300."
  },
